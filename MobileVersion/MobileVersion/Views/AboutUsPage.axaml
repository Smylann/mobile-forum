<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:MobileVersion.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
			 x:Class="MobileVersion.AboutUsPage"
			 x:DataType="vm:AboutUsVM"
			 Background="#1A1B2E">

	<Grid RowDefinitions="Auto, *">
		<!-- HEADER -->
		<Border Grid.Row="0" Padding="15,40,15,20" Background="#1A1B2E">
			<Grid ColumnDefinitions="Auto, *">
				<Button Grid.Column="0"
						Command="{Binding CloseCommand}"
						Background="Transparent"
						BorderThickness="0"
						Padding="5"
						VerticalAlignment="Center">
					<Path Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
						  Fill="White"
						  Width="24" Height="24"
						  Stretch="Uniform"/>
				</Button>
				
			</Grid>
		</Border>

		<!-- CONTENT -->
		<ScrollViewer Grid.Row="1">
			<StackPanel Spacing="25" Margin="20">
				<TextBlock Text="Creator"
				           TextAlignment="Center"
				           FontSize="24"
				           Foreground="White"
				           Background="#1A1B2E"
				           FontWeight="Bold"
				           VerticalAlignment="Center"
				           Margin="-15,0,0,0"/>
				<Border Background="#1E1F35" 
				        BorderBrush="#30314D" 
				        BorderThickness="1" 
				        CornerRadius="12" 
				        Padding="16">
					<StackPanel Spacing="6">
						<TextBlock Text="Pelyvás Milán" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
					</StackPanel>
				</Border>
				
				<TextBlock Grid.Column="1"
				           Text="SZÓSZ"
				           TextAlignment="Center"
				           FontSize="24"
				           Foreground="White"
				           FontWeight="Bold"
				           VerticalAlignment="Center"
				           Margin="-15,0,0,0"/>
				<!-- Footer / Source Section -->
				<Border Background="#1E1F35" CornerRadius="12" Padding="20">
					<StackPanel Spacing="10" HorizontalAlignment="Center">
						<TextBlock Text="https://github.com/Smylann/mobile-forum.git"
								   Foreground="White"
								   FontSize="14"
								   TextDecorations="Underline"
								   Cursor="Hand" 
								   TextWrapping="Wrap"
								   HorizontalAlignment="Center"
								   TextAlignment="Center"/>
						<Separator Background="#30314D" Margin="0,10"/>
						<TextBlock Text="A hostolás a saját szerveremen történik"
								   FontSize="12"
								   Foreground="#B0B3B8" 
								   TextWrapping="Wrap" 
								   TextAlignment="Center"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</Border>
				
				<!-- Bottom Padding for FAB safety -->
				<Border Height="40"/>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
